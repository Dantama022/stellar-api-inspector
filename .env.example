# Stellar API Inspector Configuration

# Required for tx-test command — secret key of a funded testnet account
# STELLAR_SECRET_KEY=S...

# Optional Horizon endpoint URL overrides
# HORIZON_URL=https://horizon-testnet.stellar.org

# Optional network passphrase override (defaults to testnet)
# STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Optional Soroban RPC endpoint URL overrides
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
